{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)",       "destination": "https://spurgeonproperty-production.up.railway.app/api/$1" },
    { "source": "/health",         "destination": "https://spurgeonproperty-production.up.railway.app/health" },
    { "source": "/uploads/(.*)",   "destination": "https://spurgeonproperty-production.up.railway.app/uploads/$1" },
    { "source": "/(.*)",           "destination": "/index.html" }
  ]
}
