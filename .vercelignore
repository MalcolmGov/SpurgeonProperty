# Do not ship to Vercel build env
node_modules
.next
dist

# attached_assets/ is kept — client/src/pages/services.tsx imports
# from @assets/ (alias → attached_assets/). Vite tree-shakes so only
# referenced files end up in the built output; the whole 63 MB folder
# doesn't ship to production, only the ~200 KB services image bundles in.

# Generated PDFs — re-generated on demand at runtime
*.pdf

# Python scratch files
__pycache__
*.pyc
.venv
venv

# Local env + editor
.env
.env.local
.env.*.local
.vscode
.idea

# Replit leftovers
.replit
replit.nix
.breakpoints
.upm

# Logs + debug
*.log
debug_*.json
